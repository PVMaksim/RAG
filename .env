# ── LLM Provider ─────────────────────────────────────────────────────────────
# OpenRouter API Key (получи на https://openrouter.ai/keys)
# Формат: sk-or-v1-xxxxxxxxxxxxx
OPENROUTER_API_KEY=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

# Модель Claude через OpenRouter
# Доступные модели: anthropic/claude-sonnet-4-20250514, anthropic/claude-3-5-sonnet-20241022, и др.
# Полный список: https://openrouter.ai/models
CLAUDE_MODEL=minimax/minimax-m2.5:free

# ── База данных эмбеддингов ──────────────────────────────────────────────────
CHROMA_DB_PATH=./data/chroma_db

# ── Граф зависимостей ────────────────────────────────────────────────────────
GRAPH_DB_PATH=./data/graph.db

# ── Папка с проектами для сканирования ───────────────────────────────────────
# Укажи абсолютный или относительный путь к директории с твоими IT-проектами
PROJECTS_BASE_PATH=./projects

# ── Правила сканирования ─────────────────────────────────────────────────────
RAG_RULES_PATH=./backend/rag-rules.yaml

# ── Модель эмбеддингов ───────────────────────────────────────────────────────
# Локальная модель sentence-transformers (не требует API ключа)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Количество результатов поиска ────────────────────────────────────────────
# От 1 до 20
DEFAULT_TOP_K=5

# ── MCP Сервер ───────────────────────────────────────────────────────────────
MCP_SERVER_PORT=27183

# ── Webhook Secret (опционально) ─────────────────────────────────────────────
# Для верификации GitHub Webhook запросов
# Генерируй: openssl rand -hex 32
WEBHOOK_SECRET=

# ── MCP API Key (опционально) ────────────────────────────────────────────────
# Для аутентификации MCP подключений
# Пустой = аутентификация отключена (только для локальной разработки)
MCP_API_KEY=

# ── Telegram уведомления (опционально) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=

# ── Сервер ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8000

# ── Режим отладки ────────────────────────────────────────────────────────────
# true/false
DEBUG=false

# ── CORS Origins ─────────────────────────────────────────────────────────────
# Список допустимых origins через запятую
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://frontend:3000

# ── Аутентификация (Phase 2, пока отключена) ─────────────────────────────────
AUTH_ENABLED=false